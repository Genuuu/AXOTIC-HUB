rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && (
        ('email_verified' in request.auth.token && request.auth.token.email_verified == true) || 
        ('firebase' in request.auth.token && request.auth.token.firebase.sign_in_provider == 'anonymous')
      );
    }

    function isBootstrappedAdmin() {
      return 'email' in request.auth.token && request.auth.token.email == 'genukakisara@gmail.com';
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && (
        isBootstrappedAdmin() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'admin')
      );
    }

    function isMember() {
      return isSignedIn() && (
        isBootstrappedAdmin() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         (getUserData().role == 'member' || getUserData().role == 'admin'))
      );
    }

    function isVerifiedMember() {
      return isMember() && isEmailVerified();
    }

    function isVerifiedAdmin() {
      return isAdmin() && isEmailVerified();
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if isEmailVerified() && (
        (request.auth.uid == userId && (
          request.resource.data.role == 'member' || isBootstrappedAdmin() || ('firebase' in request.auth.token && request.auth.token.firebase.sign_in_provider == 'anonymous')
        )) ||
        isVerifiedAdmin()
      );
      allow update: if isEmailVerified() && (
        (request.auth.uid == userId && 
         request.resource.data.role == resource.data.role && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'avatarUrl', 'academicYear', 'subTeam', 'specifications', 'birthday', 'isOnline', 'lastActiveAt'])) ||
        isVerifiedAdmin() ||
        ('firebase' in request.auth.token && request.auth.token.firebase.sign_in_provider == 'anonymous')
      );
      allow delete: if isVerifiedAdmin();
    }

    match /projects/{projectId} {
      allow read: if true;
      allow create: if isVerifiedMember() && request.resource.data.createdBy == request.auth.uid;
      allow update: if isVerifiedMember() && (
        isVerifiedAdmin() ||
        (resource.data.status != 'Finished' && (
          (request.auth.uid == resource.data.createdBy || request.auth.uid == resource.data.leaderId || request.auth.uid in resource.data.memberIds) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['title', 'description', 'status', 'leaderId', 'leaderName', 'memberIds', 'memberNames', 'deadline', 'startDate', 'kicadLink', 'updatedAt', 'budget', 'estimatedCost', 'costSplitType', 'memberCostSplits', 'budgetItems', 'sponsorFundings'])
        ))
      );
      allow delete: if isVerifiedAdmin() || (isVerifiedMember() && resource.data.createdBy == request.auth.uid);
    }

    match /projects/{projectId}/logs/{logId} {
      allow read: if isSignedIn();
      allow create: if isVerifiedMember() && request.resource.data.authorId == request.auth.uid;
      allow update: if isVerifiedMember() && (
        isVerifiedAdmin() ||
        (request.auth.uid == resource.data.authorId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['content']))
      );
      allow delete: if isVerifiedAdmin();
    }

    match /projects/{projectId}/hardware/{hardwareId} {
      allow read: if isSignedIn();
      allow create: if isVerifiedMember() && request.resource.data.allocatedBy == request.auth.uid;
      allow update: if isVerifiedMember() && (
        isVerifiedAdmin() ||
        (request.auth.uid == resource.data.allocatedBy && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['quantity']))
      );
      allow delete: if isVerifiedAdmin();
    }

    match /inventory/{itemId} {
      allow read: if isSignedIn();
      allow create: if isVerifiedMember();
      allow update: if isVerifiedMember() && (
        isVerifiedAdmin() ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['availableQuantity', 'name', 'category', 'description', 'totalQuantity', 'location', 'specification'])
      );
      allow delete: if isVerifiedMember() || isVerifiedAdmin();
    }

    match /categories/{categoryId} {
      allow read: if isSignedIn();
      allow write: if isVerifiedAdmin();
    }

    match /ideas/{ideaId} {
      allow read: if isSignedIn();
      allow create: if isVerifiedMember() && request.resource.data.createdBy == request.auth.uid;
      allow update: if isVerifiedMember() && (
        isVerifiedAdmin() ||
        (resource.data.status != 'Promoted' && (
          request.resource.data.diff(resource.data).affectedKeys().hasAny(['title', 'description', 'category', 'votes', 'votedIds', 'status', 'promotedProjectId', 'updatedAt', 'comments'])
        ))
      );
      allow delete: if isVerifiedAdmin() || (isVerifiedMember() && resource.data.createdBy == request.auth.uid);
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn();
      allow create: if isVerifiedMember();
      allow update: if isVerifiedMember();
      allow delete: if isVerifiedAdmin() || (isSignedIn() && request.auth.uid == resource.data.createdBy);
    }

    match /admin_logs/{logId} {
      allow read: if isVerifiedAdmin();
      allow create: if isVerifiedAdmin();
      allow update: if false; // Logs are immutable, write-once append-only
      allow delete: if isVerifiedAdmin();
    }
  }
}
